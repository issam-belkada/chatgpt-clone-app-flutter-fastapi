# Environment Configuration
DEBUG=True
APP_NAME="ChatGPT Clone API"

# Database
DATABASE_URL=sqlite:///./chatgpt.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/chatgpt

# JWT Settings
SECRET_KEY=your-super-secret-key-change-this-in-production-now
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini (primary)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Groq (fallback) — get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS
CORS_ORIGINS=["*"]